rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "joaquinvillanuevavarela@gmail.com" ||
        request.auth.token.email == "valentina@yoga.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Packages Collection ---
    match /packages/{packageId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().studentId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Classes Collection ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().studentId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Expenses Collection ---
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }
  }
}
